@model CaseForgeAI.Core.Entities.PlayerProgress
@{
    ViewData["Title"] = "Case Outcome - " + Model.Story.Title;

    var isSuccess = TempData["AccusationSuccess"] as bool? ?? Model.CaseSolved;
    var outcomeMessage = TempData["OutcomeMessage"] as string ?? (isSuccess ? "Justice has been served." : "The killer walks free.");
    var outcomeDetails = TempData["OutcomeDetails"] as string ?? "";
}

<!-- Outcome Canvas — used for confetti / rain particles -->
<canvas id="outcomeCanvas" class="fixed top-0 left-0 w-full h-full pointer-events-none z-20"></canvas>

<!-- Full-screen cinematic overlay that fades out to reveal the content -->
<div id="curtain" class="fixed inset-0 z-30 bg-noir-obsidian flex items-center justify-center">
    <div id="curtainIcon" class="text-center opacity-0">
        @if (isSuccess)
        {
            <i class="fa-solid fa-scale-balanced text-noir-gold text-7xl md:text-9xl drop-shadow-[0_0_40px_rgba(212,175,55,0.6)]"></i>
        }
        else
        {
            <i class="fa-solid fa-skull text-red-600 text-7xl md:text-9xl drop-shadow-[0_0_40px_rgba(220,38,38,0.5)]"></i>
        }
    </div>
</div>

<div class="relative z-10 space-y-10 pb-16">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  HEADER BADGE                                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div id="headerBlock" class="opacity-0 text-center pt-6 space-y-5">

        <!-- Decorative top flourish -->
        <div class="flex items-center justify-center space-x-4">
            <span class="block w-16 md:w-32 h-px @(isSuccess ? "bg-gradient-to-r from-transparent to-noir-gold" : "bg-gradient-to-r from-transparent to-red-800")"></span>
            @if (isSuccess)
            {
                <i class="fa-solid fa-star text-noir-gold text-xs animate-pulse"></i>
                <i class="fa-solid fa-star text-noir-gold text-sm animate-pulse"></i>
                <i class="fa-solid fa-star text-noir-gold text-xs animate-pulse"></i>
            }
            else
            {
                <i class="fa-solid fa-xmark text-red-600 text-sm"></i>
            }
            <span class="block w-16 md:w-32 h-px @(isSuccess ? "bg-gradient-to-l from-transparent to-noir-gold" : "bg-gradient-to-l from-transparent to-red-800")"></span>
        </div>

        <!-- Main verdict -->
        <h1 id="verdictTitle"
            class="font-serif text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-[0.25em] uppercase
                   @(isSuccess
                       ? "text-noir-gold drop-shadow-[0_0_50px_rgba(212,175,55,0.5)]"
                       : "text-red-600 drop-shadow-[0_0_50px_rgba(220,38,38,0.4)]")">
            @(isSuccess ? "CASE SOLVED" : "CASE UNSOLVED")
        </h1>

        <p class="font-serif text-sm md:text-base tracking-[0.3em] uppercase @(isSuccess ? "text-noir-brass" : "text-red-400/70")">
            @(isSuccess ? "The Bureau commends your service, Detective" : "The shadows have claimed another victory")
        </p>

        <!-- Bottom flourish -->
        <div class="w-24 h-[2px] mx-auto @(isSuccess ? "bg-gradient-to-r from-transparent via-noir-gold to-transparent" : "bg-gradient-to-r from-transparent via-red-700 to-transparent")"></div>
    </div>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  SCORE DISPLAY                                         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div id="scoreBlock" class="opacity-0 flex justify-center">
        <div class="relative group">
            <!-- Outer glow ring -->
            <div class="absolute -inset-4 rounded-full blur-2xl opacity-40
                        @(isSuccess ? "bg-noir-gold/30" : "bg-red-700/20") group-hover:opacity-60 transition duration-700"></div>

            <div class="relative w-44 h-44 md:w-56 md:h-56 rounded-full flex flex-col items-center justify-center
                        border-2 @(isSuccess ? "border-noir-gold/60" : "border-red-700/40")
                        bg-noir-charcoal/80 backdrop-blur-sm shadow-2xl">
                <span class="text-[10px] font-serif uppercase tracking-[0.3em] @(isSuccess ? "text-noir-brass" : "text-red-400/70") mb-1">Final Score</span>
                <span id="scoreValue"
                      class="font-serif text-5xl md:text-6xl font-extrabold @(isSuccess ? "text-noir-gold" : "text-red-500")"
                      data-target="@Model.Score">0</span>
                <span class="text-[10px] font-sans uppercase tracking-widest text-noir-ivory/40 mt-1">points</span>
            </div>
        </div>
    </div>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  OUTCOME MESSAGE CARD                                  -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div id="messageCard" class="opacity-0 max-w-3xl mx-auto">
        <div class="rounded-xl p-8 md:p-10
                    @(isSuccess
                        ? "bg-gradient-to-b from-noir-charcoal to-noir-charcoal/60 border border-noir-gold/20 shadow-[0_0_40px_rgba(212,175,55,0.08)]"
                        : "bg-gradient-to-b from-noir-charcoal to-[#1a0a0a]/60 border border-red-900/30 shadow-[0_0_40px_rgba(127,29,29,0.1)]")">

            <!-- Quote / Icon -->
            <div class="flex justify-center mb-6">
                @if (isSuccess)
                {
                    <div class="w-14 h-14 rounded-full bg-noir-gold/10 border border-noir-gold/30 flex items-center justify-center">
                        <i class="fa-solid fa-check-double text-noir-gold text-xl"></i>
                    </div>
                }
                else
                {
                    <div class="w-14 h-14 rounded-full bg-red-900/20 border border-red-800/30 flex items-center justify-center">
                        <i class="fa-solid fa-triangle-exclamation text-red-500 text-xl"></i>
                    </div>
                }
            </div>

            <h2 class="font-serif text-xl md:text-2xl font-bold text-center mb-4 @(isSuccess ? "text-noir-gold" : "text-red-400")">
                @outcomeMessage
            </h2>

            @if (!string.IsNullOrWhiteSpace(outcomeDetails))
            {
                <p class="text-noir-ivory/70 text-sm md:text-base leading-relaxed text-center font-sans">
                    @outcomeDetails
                </p>
            }
        </div>
    </div>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  STORY ENDING NARRATIVE                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    @if (!string.IsNullOrWhiteSpace(Model.Story?.Ending))
    {
        <div id="endingBlock" class="opacity-0 max-w-3xl mx-auto">
            <div class="relative rounded-xl p-8 md:p-10 bg-noir-charcoal/50 border border-white/5">

                <!-- Decorative corner marks -->
                <span class="absolute top-3 left-3 w-4 h-4 border-t border-l @(isSuccess ? "border-noir-gold/30" : "border-red-800/30")"></span>
                <span class="absolute top-3 right-3 w-4 h-4 border-t border-r @(isSuccess ? "border-noir-gold/30" : "border-red-800/30")"></span>
                <span class="absolute bottom-3 left-3 w-4 h-4 border-b border-l @(isSuccess ? "border-noir-gold/30" : "border-red-800/30")"></span>
                <span class="absolute bottom-3 right-3 w-4 h-4 border-b border-r @(isSuccess ? "border-noir-gold/30" : "border-red-800/30")"></span>

                <div class="flex items-center space-x-3 mb-6">
                    <i class="fa-solid fa-book-open @(isSuccess ? "text-noir-gold" : "text-red-500/70") text-lg"></i>
                    <h3 class="font-serif text-lg tracking-wider uppercase @(isSuccess ? "text-noir-gold" : "text-red-400/80")">
                        Case Epilogue
                    </h3>
                </div>

                <div class="w-full h-px @(isSuccess ? "bg-noir-gold/10" : "bg-red-800/15") mb-6"></div>

                <p id="endingText" class="text-noir-ivory/80 text-sm md:text-base leading-loose font-sans italic">
                    @Model.Story.Ending
                </p>

                <div class="mt-8 text-right">
                    <span class="font-serif text-xs tracking-[0.2em] uppercase @(isSuccess ? "text-noir-brass/60" : "text-red-400/40")">
                        &mdash; Bureau Case File #@Model.StoryId.ToString().Substring(0, 8).ToUpper()
                    </span>
                </div>
            </div>
        </div>
    }


    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  CASE STATS SUMMARY                                    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div id="statsBlock" class="opacity-0 max-w-3xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
            <div class="rounded-lg p-4 bg-noir-charcoal/40 border border-white/5">
                <i class="fa-solid fa-fingerprint text-noir-gold/60 text-lg mb-2"></i>
                <div class="text-xs font-serif uppercase tracking-wider text-noir-brass/60 mb-1">Verdict</div>
                <div class="font-serif font-bold text-sm @(isSuccess ? "text-noir-gold" : "text-red-400")">
                    @(isSuccess ? "Guilty" : "At Large")
                </div>
            </div>
            <div class="rounded-lg p-4 bg-noir-charcoal/40 border border-white/5">
                <i class="fa-solid fa-trophy text-noir-gold/60 text-lg mb-2"></i>
                <div class="text-xs font-serif uppercase tracking-wider text-noir-brass/60 mb-1">Score</div>
                <div class="font-serif font-bold text-sm text-noir-ivory">@Model.Score</div>
            </div>
            <div class="rounded-lg p-4 bg-noir-charcoal/40 border border-white/5">
                <i class="fa-solid fa-clock text-noir-gold/60 text-lg mb-2"></i>
                <div class="text-xs font-serif uppercase tracking-wider text-noir-brass/60 mb-1">Difficulty</div>
                <div class="font-serif font-bold text-sm text-noir-ivory">@Model.Story?.Difficulty</div>
            </div>
            <div class="rounded-lg p-4 bg-noir-charcoal/40 border border-white/5">
                <i class="fa-solid fa-folder-closed text-noir-gold/60 text-lg mb-2"></i>
                <div class="text-xs font-serif uppercase tracking-wider text-noir-brass/60 mb-1">Status</div>
                <div class="font-serif font-bold text-sm @(isSuccess ? "text-green-400" : "text-red-400")">
                    @(isSuccess ? "Closed" : "Cold Case")
                </div>
            </div>
        </div>
    </div>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  ACTION BUTTONS                                        -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div id="actionsBlock" class="opacity-0 flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <!-- Return to Lobby -->
        <a asp-controller="Home" asp-action="Index"
           class="group relative inline-flex items-center space-x-3 px-8 py-4 rounded-lg font-serif text-sm uppercase tracking-[0.2em] font-bold transition-all duration-300
                  bg-gradient-to-r from-noir-bronze to-noir-gold text-noir-obsidian
                  hover:shadow-[0_0_30px_rgba(212,175,55,0.4)] hover:scale-105">
            <i class="fa-solid fa-building-columns text-lg"></i>
            <span>Return to Lobby</span>
        </a>

        <!-- Play Again -->
        <a asp-controller="Gameplay" asp-action="StartCase" asp-route-id="@Model.StoryId"
           class="group relative inline-flex items-center space-x-3 px-8 py-4 rounded-lg font-serif text-sm uppercase tracking-[0.2em] font-bold transition-all duration-300
                  border @(isSuccess ? "border-noir-gold/40 text-noir-gold hover:bg-noir-gold/10" : "border-red-700/40 text-red-400 hover:bg-red-900/10")
                  hover:scale-105">
            <i class="fa-solid fa-rotate-right text-lg"></i>
            <span>Play Again</span>
        </a>
    </div>

    <!-- Bureau Stamp -->
    <div id="stampBlock" class="opacity-0 text-center pt-4 pb-8">
        <div class="inline-block border-2 @(isSuccess ? "border-noir-gold/20" : "border-red-800/20") rounded-lg px-6 py-3 transform -rotate-2">
            <span class="font-serif text-[10px] tracking-[0.4em] uppercase @(isSuccess ? "text-noir-gold/40" : "text-red-600/30")">
                <i class="fa-solid fa-stamp mr-2"></i>Bureau of Forensic Analytics &bull; Case @(isSuccess ? "Closed" : "Suspended") &bull; @DateTime.UtcNow.ToString("yyyy-MM-dd")
            </span>
        </div>
    </div>
</div>


@section Scripts {
<script>
(function () {
    const isSuccess = @(isSuccess ? "true" : "false");
    const targetScore = parseInt(document.getElementById('scoreValue')?.dataset.target || '0', 10);

    // ── Particle System (Confetti or Rain) ──────────────────────
    const canvas = document.getElementById('outcomeCanvas');
    const ctx = canvas.getContext('2d');
    let particles = [];
    let animFrameId;

    function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    class Particle {
        constructor() {
            this.reset();
        }
        reset() {
            this.x = Math.random() * canvas.width;
            this.y = -10 - Math.random() * canvas.height;
            this.size = Math.random() * 4 + 2;
            this.speedY = Math.random() * 3 + 1.5;
            this.speedX = (Math.random() - 0.5) * 2;
            this.opacity = Math.random() * 0.7 + 0.3;
            this.rotation = Math.random() * 360;
            this.rotSpeed = (Math.random() - 0.5) * 6;

            if (isSuccess) {
                const palette = ['#D4AF37', '#C5A880', '#FFD700', '#F5EFEB', '#8E7544'];
                this.color = palette[Math.floor(Math.random() * palette.length)];
                this.shape = Math.random() > 0.5 ? 'rect' : 'circle';
            } else {
                this.color = `rgba(${120 + Math.random()*60}, ${Math.random()*30}, ${Math.random()*30}, ${this.opacity})`;
                this.shape = 'circle';
                this.size = Math.random() * 2 + 1;
                this.speedY = Math.random() * 5 + 3;
                this.speedX = Math.random() * 0.5 - 0.25;
            }
        }
        update() {
            this.y += this.speedY;
            this.x += this.speedX;
            this.rotation += this.rotSpeed;
            if (this.y > canvas.height + 20) this.reset();
        }
        draw() {
            ctx.save();
            ctx.translate(this.x, this.y);
            ctx.rotate((this.rotation * Math.PI) / 180);
            ctx.globalAlpha = this.opacity;

            if (this.shape === 'rect') {
                ctx.fillStyle = this.color;
                ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size * 0.6);
            } else {
                ctx.beginPath();
                ctx.arc(0, 0, this.size / 2, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.fill();
            }
            ctx.restore();
        }
    }

    function spawnParticles(count) {
        for (let i = 0; i < count; i++) particles.push(new Particle());
    }

    function animateParticles() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(); });
        animFrameId = requestAnimationFrame(animateParticles);
    }

    // ── Score Counter Animation ─────────────────────────────────
    function animateScore() {
        const el = document.getElementById('scoreValue');
        if (!el) return;
        const duration = 2000;
        const start = performance.now();
        function tick(now) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease-out quart
            const eased = 1 - Math.pow(1 - progress, 4);
            el.textContent = Math.round(eased * targetScore);
            if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
    }

    // ── GSAP Cinematic Reveal Timeline ──────────────────────────
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Phase 1: Curtain icon slam
    tl.to('#curtainIcon', {
        opacity: 1,
        scale: 1.3,
        duration: 0.6,
        delay: 0.3,
        ease: 'back.out(2)'
    })
    .to('#curtainIcon', {
        scale: 1,
        duration: 0.3,
    })
    // Phase 2: Hold the icon, then sweep curtain away
    .to('#curtain', {
        opacity: 0,
        duration: 0.8,
        delay: 1.0,
        ease: 'power2.inOut',
        onComplete: () => {
            document.getElementById('curtain').style.display = 'none';
            // Start particles after curtain lifts
            spawnParticles(isSuccess ? 120 : 50);
            animateParticles();
        }
    })
    // Phase 3: Reveal header with dramatic scale
    .fromTo('#headerBlock', {
        opacity: 0,
        y: 40,
        scale: 0.9,
    }, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.0,
    })
    // Phase 4: Verdict title glitch/shimmer
    .fromTo('#verdictTitle', {
        letterSpacing: '0.6em',
        filter: 'blur(8px)',
    }, {
        letterSpacing: '0.25em',
        filter: 'blur(0px)',
        duration: 0.8,
        ease: 'power4.out',
    }, '-=0.6')
    // Phase 5: Score circle enters
    .fromTo('#scoreBlock', {
        opacity: 0,
        scale: 0.5,
        rotation: -10,
    }, {
        opacity: 1,
        scale: 1,
        rotation: 0,
        duration: 0.8,
        ease: 'back.out(1.4)',
        onStart: animateScore,
    })
    // Phase 6: Message card slides up
    .fromTo('#messageCard', {
        opacity: 0,
        y: 60,
    }, {
        opacity: 1,
        y: 0,
        duration: 0.7,
    }, '-=0.3')
    // Phase 7: Ending narrative fades in
    .fromTo('#endingBlock', {
        opacity: 0,
        y: 40,
    }, {
        opacity: 1,
        y: 0,
        duration: 0.8,
    }, '-=0.2')
    // Phase 8: Stats grid staggers in
    .fromTo('#statsBlock', {
        opacity: 0,
        y: 30,
    }, {
        opacity: 1,
        y: 0,
        duration: 0.6,
    }, '-=0.3')
    .fromTo('#statsBlock .rounded-lg', {
        opacity: 0,
        y: 20,
        scale: 0.9,
    }, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 0.4,
        stagger: 0.1,
        ease: 'back.out(1.2)',
    }, '-=0.3')
    // Phase 9: Action buttons
    .fromTo('#actionsBlock', {
        opacity: 0,
        y: 20,
    }, {
        opacity: 1,
        y: 0,
        duration: 0.5,
    }, '-=0.1')
    // Phase 10: Bureau stamp slams in
    .fromTo('#stampBlock', {
        opacity: 0,
        scale: 2,
        rotation: -8,
    }, {
        opacity: 1,
        scale: 1,
        rotation: -2,
        duration: 0.4,
        ease: 'back.out(2)',
    });

    // ── Continuous subtle glow pulse on verdict ─────────────────
    gsap.to('#verdictTitle', {
        textShadow: isSuccess
            ? '0 0 60px rgba(212,175,55,0.6), 0 0 120px rgba(212,175,55,0.2)'
            : '0 0 60px rgba(220,38,38,0.5), 0 0 120px rgba(220,38,38,0.15)',
        duration: 2,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: 4,
    });

    // ── Gradually reduce particles after 10 seconds ─────────────
    setTimeout(() => {
        const fadeInterval = setInterval(() => {
            if (particles.length > 20) {
                particles.splice(0, 5);
            } else {
                clearInterval(fadeInterval);
            }
        }, 500);
    }, 10000);

})();
</script>
}
