@model CaseForgeAI.Core.Entities.PlayerProgress

@{
    ViewData["Title"] = "Interrogation - " + Model.Story!.Title;
    var suspects = Model.Story.Suspects;
}

<!-- ─────────────────── INLINE STYLES ─────────────────── -->
<style>
    /* Interrogation room spotlight cone */
    .spotlight {
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 900px;
        background: radial-gradient(ellipse at 50% 0%, rgba(212,175,55,0.07) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }

    /* Subtle horizontal scan-line overlay */
    .scanlines {
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
            0deg,
            transparent,
            transparent 2px,
            rgba(0,0,0,0.04) 2px,
            rgba(0,0,0,0.04) 4px
        );
        pointer-events: none;
        z-index: 1;
    }

    /* Flicker animation for the overhead lamp */
    @@keyframes lampFlicker {
        0%, 95%, 100% { opacity: 1; }
        96% { opacity: 0.6; }
        97% { opacity: 1; }
        98% { opacity: 0.7; }
    }

    .lamp-flicker { animation: lampFlicker 6s ease-in-out infinite; }

    /* Typewriter cursor blink */
    @@keyframes cursorBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    .typewriter-cursor::after {
        content: '▌';
        color: #D4AF37;
        animation: cursorBlink 0.7s step-end infinite;
        margin-left: 2px;
    }

    /* Gold shimmer for the header accent line */
    @@keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    .shimmer-line {
        background: linear-gradient(90deg, transparent 0%, #D4AF37 50%, transparent 100%);
        background-size: 200% 100%;
        animation: shimmer 4s linear infinite;
    }

    /* Suspect card hover lift */
    .suspect-card {
        transition: transform 0.35s cubic-bezier(.25,.8,.25,1), box-shadow 0.35s cubic-bezier(.25,.8,.25,1);
    }
    .suspect-card:hover {
        transform: translateY(-6px) scale(1.015);
        box-shadow: 0 12px 40px rgba(212,175,55,0.12), 0 0 60px rgba(212,175,55,0.05);
    }

    /* Dialogue panel slide-in */
    .dialogue-panel {
        transform: translateY(30px);
        opacity: 0;
        transition: transform 0.5s cubic-bezier(.22,1,.36,1), opacity 0.5s ease;
    }
    .dialogue-panel.active {
        transform: translateY(0);
        opacity: 1;
    }
</style>

<!-- ─────────────────── ATMOSPHERIC OVERLAYS ─────────────────── -->
<div class="spotlight lamp-flicker"></div>
<div class="scanlines"></div>

<!-- ─────────────────── MAIN CONTENT ─────────────────── -->
<div class="relative z-10 space-y-10">

    <!-- ══════════ HEADER ══════════ -->
    <header class="text-center space-y-4 pt-4" id="pageHeader">
        <!-- Case badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-noir-gold/20 bg-noir-charcoal/60 backdrop-blur text-xs font-sans uppercase tracking-[0.25em] text-noir-brass">
            <i class="fa-solid fa-folder-open text-noir-gold"></i>
            @Model.Story.Title
        </div>

        <!-- Main title -->
        <h1 class="font-serif text-4xl md:text-5xl tracking-wide text-noir-ivory">
            <i class="fa-solid fa-comments text-noir-gold mr-3 text-3xl md:text-4xl"></i>
            Interrogation <span class="text-noir-gold">Room</span>
        </h1>

        <!-- Shimmer divider -->
        <div class="mx-auto w-64 h-px shimmer-line rounded-full"></div>

        <!-- Score display -->
        <div class="flex items-center justify-center gap-6 text-sm font-sans">
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-noir-charcoal/70 border border-noir-gold/15">
                <i class="fa-solid fa-star text-noir-gold"></i>
                <span class="text-noir-brass">Score:</span>
                <span class="text-white font-bold" id="scoreValue">@Model.Score</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-noir-charcoal/70 border border-noir-gold/15">
                <i class="fa-solid fa-user-secret text-noir-gold"></i>
                <span class="text-noir-brass">Suspects:</span>
                <span class="text-white font-bold">@suspects.Count</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-noir-emerald/40 border border-green-500/15">
                <i class="fa-solid fa-signal text-green-400"></i>
                <span class="text-green-300 text-xs uppercase tracking-wider font-semibold">Stage: Interrogation</span>
            </div>
        </div>
    </header>

    <!-- ══════════ SUSPECT GRID ══════════ -->
    <section id="suspectGrid">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-8 bg-noir-gold rounded-full"></div>
            <h2 class="font-serif text-xl tracking-wider text-noir-brass uppercase">Persons of Interest</h2>
        </div>

        @if (!suspects.Any())
        {
            <div class="text-center py-16 bg-noir-charcoal/40 rounded-xl border border-noir-gold/10">
                <i class="fa-solid fa-ghost text-5xl text-noir-gold/30 mb-4"></i>
                <p class="text-noir-brass text-sm">No suspects have been identified in this case yet.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var suspect in suspects)
                {
                    <div class="suspect-card group relative rounded-xl border border-noir-gold/10 bg-gradient-to-b from-noir-charcoal/90 to-noir-obsidian/80 backdrop-blur overflow-hidden"
                         data-suspect-id="@suspect.Id">

                        <!-- Gold accent bar at top -->
                        <div class="absolute top-0 inset-x-0 h-0.5 bg-gradient-to-r from-transparent via-noir-gold/40 to-transparent group-hover:via-noir-gold/70 transition-all duration-500"></div>

                        <!-- Interior spotlight glow on hover -->
                        <div class="absolute inset-0 bg-gradient-to-b from-noir-gold/0 to-noir-gold/0 group-hover:from-noir-gold/5 group-hover:to-transparent transition-all duration-500 pointer-events-none"></div>

                        <div class="relative p-5 space-y-4">

                            <!-- Avatar & Identity -->
                            <div class="flex flex-col md:flex-row gap-6">
                                <!-- Avatar circle -->
                                <div class="relative flex-shrink-0">
                                    <div class="w-16 h-16 rounded-full bg-noir-charcoal border-2 border-noir-gold/20 flex items-center justify-center group-hover:border-noir-gold/50 transition-colors duration-300 overflow-hidden">
                                        <i class="fa-solid fa-user-secret text-2xl text-noir-gold/50 group-hover:text-noir-gold transition-colors duration-300"></i>
                                    </div>
                                    <!-- Status indicator dot -->
                                    <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full bg-noir-charcoal border-2 border-noir-gold/30 flex items-center justify-center">
                                        <div class="w-1.5 h-1.5 rounded-full bg-noir-gold/60"></div>
                                    </div>
                                </div>

                                <!-- Name & Role -->
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-serif text-lg text-noir-ivory group-hover:text-white transition-colors duration-300 truncate">
                                        @suspect.Name
                                    </h3>
                                    <span class="inline-flex items-center gap-1.5 mt-1 px-2.5 py-0.5 rounded-full text-[10px] font-sans uppercase tracking-widest bg-noir-gold/10 text-noir-gold border border-noir-gold/15">
                                        <i class="fa-solid fa-id-badge text-[8px]"></i>
                                        @suspect.Role
                                    </span>
                                </div>
                            </div>

                            <!-- Description snippet -->
                            <p class="text-xs text-noir-brass/80 leading-relaxed line-clamp-3 font-sans">
                                @(suspect.Description.Length > 140 ? suspect.Description.Substring(0, 140) + "…" : suspect.Description)
                            </p>

                            <!-- Divider -->
                            <div class="overflow-x-auto"><table class="w-full table-auto border-collapse">nt-to-r from-transparent via-noir-gold/15 to-transparent"></div>

                            <!-- Interrogate and Accuse buttons -->
                            <div class="grid grid-cols-2 gap-2">
                                <button onclick="interrogateSuspect('@suspect.Id', '@suspect.Name.Replace("'", "\\'")' )"
                                        class="interrogate-btn flex items-center justify-center gap-2 py-2.5 rounded-lg text-xs font-serif uppercase tracking-[0.1em]
                                               border border-noir-gold/20 bg-noir-gold/5 text-noir-gold
                                               hover:bg-noir-gold hover:text-noir-obsidian active:scale-95 transition-all duration-300">
                                    <i class="fa-solid fa-microphone"></i>
                                    <span>Question</span>
                                </button>
                                
                                <form asp-action="SubmitAccusation" method="post" class="m-0">
                                    <input type="hidden" name="progressId" value="@Model.Id" />
                                    <input type="hidden" name="suspectId" value="@suspect.Id" />
                                    <button type="submit" 
                                            class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg text-xs font-serif uppercase tracking-[0.1em]
                                                   border border-red-500/20 bg-red-500/5 text-red-400
                                                   hover:bg-red-500 hover:text-white active:scale-95 transition-all duration-300"
                                            onclick="return confirm('Are you sure you want to accuse @suspect.Name.Replace("'", "\\'")? This is your final decision!');">
                                        <i class="fa-solid fa-gavel"></i>
                                        <span>Accuse</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ══════════ INTERROGATION DIALOGUE PANEL ══════════ -->
    <section id="dialogueSection" class="hidden">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-8 bg-red-500 rounded-full"></div>
            <h2 class="font-serif text-xl tracking-wider text-noir-brass uppercase">Active Interrogation</h2>
        </div>

        <div id="dialoguePanel" class="dialogue-panel rounded-2xl border border-noir-gold/15 bg-gradient-to-br from-noir-charcoal via-noir-charcoal/95 to-noir-obsidian overflow-hidden shadow-2xl">
            <!-- Overhead lamp icon -->
            <div class="flex justify-center pt-6">
                <div class="w-12 h-12 rounded-full bg-noir-gold/10 border border-noir-gold/20 flex items-center justify-center lamp-flicker">
                    <i class="fa-solid fa-lightbulb text-xl text-noir-gold"></i>
                </div>
            </div>

            <div class="p-6 md:p-8 space-y-6">
                <!-- Suspect identity row -->
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-full bg-noir-obsidian border-2 border-red-500/30 flex items-center justify-center">
                        <i class="fa-solid fa-user-secret text-xl text-red-400"></i>
                    </div>
                    <div>
                        <h3 id="dialogueSuspectName" class="font-serif text-2xl text-white"></h3>
                        <span class="text-[10px] font-sans uppercase tracking-widest text-red-400">
                            <i class="fa-solid fa-circle text-[5px] mr-1 animate-pulse"></i>Under Interrogation
                        </span>
                    </div>
                </div>

                <!-- Dialogue box -->
                <div class="relative bg-noir-obsidian/60 rounded-xl border border-noir-gold/10 p-5">
                    <!-- Quotation mark decoration -->
                    <div class="absolute -top-3 left-4 text-4xl text-noir-gold/20 font-serif leading-none">"</div>
                    <p id="dialogueText" class="text-noir-ivory/90 font-sans text-sm md:text-base leading-relaxed italic pl-4 typewriter-cursor"></p>
                </div>

                <!-- Motive reveal -->
                <div id="motiveSection" class="bg-noir-forest/40 rounded-xl border border-green-500/15 p-5 space-y-2">
                    <div class="flex items-center gap-2 text-xs font-sans uppercase tracking-widest text-green-400">
                        <i class="fa-solid fa-brain"></i>
                        <span>Suspected Motive</span>
                    </div>
                    <p id="motiveText" class="text-noir-ivory/80 text-sm font-sans leading-relaxed"></p>
                </div>

                <!-- Actions -->
                <div class="flex justify-between items-center pt-4 border-t border-noir-gold/10">
                    <form asp-action="SubmitAccusation" asp-controller="Gameplay" method="post" id="accuseForm" class="m-0" onsubmit="return confirm('Are you sure you want to accuse this suspect? If you are wrong, you will fail the case and lose your points!')">
                        <input type="hidden" name="progressId" value="@Model.Id" />
                        <input type="hidden" name="suspectId" id="accuseSuspectId" value="" />
                        <button type="submit" class="flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-serif uppercase tracking-widest
                                       bg-red-950/40 border border-red-500/30 text-red-400 hover:bg-red-600 hover:text-white transition-all duration-300 shadow-[0_0_15px_rgba(239,68,68,0.2)] hover:shadow-[0_0_25px_rgba(239,68,68,0.5)]">
                            <i class="fa-solid fa-gavel text-sm"></i>
                            Accuse Suspect
                        </button>
                    </form>

                    <button onclick="dismissDialogue()" class="flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-serif uppercase tracking-widest
                                   border border-noir-gold/20 text-noir-brass hover:bg-noir-gold/10 hover:text-white transition-all duration-300">
                        <i class="fa-solid fa-xmark"></i>
                        End Questioning
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════ NAVIGATION ══════════ -->
    <nav class="pt-4 pb-8">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-8 bg-noir-brass rounded-full"></div>
            <h2 class="font-serif text-xl tracking-wider text-noir-brass uppercase">Case Actions</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Investigation -->
            <a asp-action="Investigation" asp-route-id="@Model.Id"
               class="group flex flex-col items-center gap-3 p-5 rounded-xl border border-noir-gold/10 bg-noir-charcoal/50 backdrop-blur
                      hover:border-noir-gold/30 hover:bg-noir-charcoal/70 transition-all duration-300">
                <div class="w-12 h-12 rounded-full bg-noir-gold/10 border border-noir-gold/15 flex items-center justify-center group-hover:bg-noir-gold/20 transition-colors duration-300">
                    <i class="fa-solid fa-magnifying-glass text-noir-gold"></i>
                </div>
                <span class="font-serif text-xs uppercase tracking-widest text-noir-brass group-hover:text-white transition-colors duration-300">Investigation</span>
            </a>

            <!-- Evidence Board -->
            <a asp-action="EvidenceBoard" asp-route-id="@Model.Id"
               class="group flex flex-col items-center gap-3 p-5 rounded-xl border border-noir-gold/10 bg-noir-charcoal/50 backdrop-blur
                      hover:border-noir-gold/30 hover:bg-noir-charcoal/70 transition-all duration-300">
                <div class="w-12 h-12 rounded-full bg-noir-gold/10 border border-noir-gold/15 flex items-center justify-center group-hover:bg-noir-gold/20 transition-colors duration-300">
                    <i class="fa-solid fa-diagram-project text-noir-gold"></i>
                </div>
                <span class="font-serif text-xs uppercase tracking-widest text-noir-brass group-hover:text-white transition-colors duration-300">Evidence Board</span>
            </a>

            <!-- Puzzles -->
            <a asp-action="Puzzles" asp-route-id="@Model.Id"
               class="group flex flex-col items-center gap-3 p-5 rounded-xl border border-noir-gold/10 bg-noir-charcoal/50 backdrop-blur
                      hover:border-noir-gold/30 hover:bg-noir-charcoal/70 transition-all duration-300">
                <div class="w-12 h-12 rounded-full bg-noir-gold/10 border border-noir-gold/15 flex items-center justify-center group-hover:bg-noir-gold/20 transition-colors duration-300">
                    <i class="fa-solid fa-puzzle-piece text-noir-gold"></i>
                </div>
                <span class="font-serif text-xs uppercase tracking-widest text-noir-brass group-hover:text-white transition-colors duration-300">Puzzles</span>
            </a>
        </div>
    </nav>
</div>

<!-- ─────────────────── LOADING OVERLAY ─────────────────── -->
<div id="loadingOverlay" class="hidden fixed inset-0 z-50 bg-noir-obsidian/80 backdrop-blur-sm flex items-center justify-center">
    <div class="flex flex-col items-center gap-4">
        <div class="w-12 h-12 border-2 border-noir-gold/20 border-t-noir-gold rounded-full animate-spin"></div>
        <span class="font-serif text-sm uppercase tracking-widest text-noir-gold">Interrogating suspect…</span>
    </div>
</div>

@section Scripts {
<script>
    // ─────────────────── URLS ───────────────────
    const interrogateUrl = '@Url.Action("InterrogateSuspectJson", "Gameplay")';
    const progressId     = '@Model.Id';

    // ─────────────────── GSAP ENTRANCE ───────────────────
    document.addEventListener('DOMContentLoaded', () => {
        // Header entrance
        gsap.from('#pageHeader', {
            y: -40, opacity: 0, duration: 0.8,
            ease: 'power3.out'
        });

        // Suspect cards stagger in
        gsap.from('.suspect-card', {
            y: 50, opacity: 0, duration: 0.6,
            stagger: 0.12, ease: 'power2.out', delay: 0.3
        });

        // Nav links stagger in
        gsap.from('nav a', {
            y: 30, opacity: 0, duration: 0.5,
            stagger: 0.08, ease: 'power2.out', delay: 0.6
        });
    });

    // ─────────────────── INTERROGATE ───────────────────
    async function interrogateSuspect(suspectId, suspectName) {
        const overlay  = document.getElementById('loadingOverlay');
        const section  = document.getElementById('dialogueSection');
        const panel    = document.getElementById('dialoguePanel');

        // Show loader
        overlay.classList.remove('hidden');

        try {
            const formData = new FormData();
            formData.append('progressId', progressId);
            formData.append('suspectId', suspectId);

            const response = await fetch(interrogateUrl, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            });

            const data = await response.json();
            overlay.classList.add('hidden');

            if (data.success) {
                // Populate panel
                document.getElementById('dialogueSuspectName').textContent = data.name;
                document.getElementById('motiveText').textContent = data.motive;
                document.getElementById('accuseSuspectId').value = suspectId;

                // Clear previous dialogue text
                const dialogueEl = document.getElementById('dialogueText');
                dialogueEl.textContent = '';

                // Show the dialogue section
                section.classList.remove('hidden');

                // Activate the panel with a brief delay for the CSS transition
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        panel.classList.add('active');
                    });
                });

                // Smooth scroll to dialogue
                section.scrollIntoView({ behavior: 'smooth', block: 'center' });

                // Typewriter effect
                typewriterEffect(dialogueEl, data.dialogue, 28);

                // Highlight the interrogated card
                document.querySelectorAll('.suspect-card').forEach(card => {
                    card.classList.remove('ring-2', 'ring-red-500/40');
                });
                const activeCard = document.querySelector(`[data-suspect-id="${suspectId}"]`);
                if (activeCard) {
                    activeCard.classList.add('ring-2', 'ring-red-500/40');
                }

                // GSAP emphasis on motive section
                gsap.from('#motiveSection', {
                    x: -30, opacity: 0, duration: 0.6,
                    delay: 1.5, ease: 'power2.out'
                });

            } else {
                showToast(data.message || 'Interrogation failed.', 'error');
            }
        } catch (err) {
            overlay.classList.add('hidden');
            showToast('Network error. Try again.', 'error');
            console.error('Interrogation error:', err);
        }
    }

    // ─────────────────── TYPEWRITER ───────────────────
    function typewriterEffect(element, text, speed) {
        let i = 0;
        element.classList.add('typewriter-cursor');
        function type() {
            if (i < text.length) {
                element.textContent += text.charAt(i);
                i++;
                setTimeout(type, speed);
            } else {
                element.classList.remove('typewriter-cursor');
            }
        }
        type();
    }

    // ─────────────────── DISMISS DIALOGUE ───────────────────
    function dismissDialogue() {
        const panel   = document.getElementById('dialoguePanel');
        const section = document.getElementById('dialogueSection');

        panel.classList.remove('active');

        // Remove card highlight
        document.querySelectorAll('.suspect-card').forEach(card => {
            card.classList.remove('ring-2', 'ring-red-500/40');
        });

        setTimeout(() => {
            section.classList.add('hidden');
            // Scroll back to suspect grid
            document.getElementById('suspectGrid').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 500);
    }

    // ─────────────────── TOAST NOTIFICATION ───────────────────
    function showToast(message, type) {
        const toast = document.createElement('div');
        const isError = type === 'error';
        toast.className = `fixed bottom-6 right-6 z-[999] flex items-center gap-3 px-5 py-3 rounded-lg border shadow-2xl
                           font-sans text-sm transition-all duration-500 transform translate-y-4 opacity-0
                           ${isError
                               ? 'bg-red-950/90 border-red-500/30 text-red-300'
                               : 'bg-noir-charcoal/90 border-noir-gold/30 text-noir-gold'}`;
        toast.innerHTML = `<i class="fa-solid ${isError ? 'fa-circle-exclamation' : 'fa-circle-check'}"></i><span>${message}</span>`;
        document.body.appendChild(toast);

        requestAnimationFrame(() => {
            toast.classList.remove('translate-y-4', 'opacity-0');
        });

        setTimeout(() => {
            toast.classList.add('translate-y-4', 'opacity-0');
            setTimeout(() => toast.remove(), 500);
        }, 4000);
    }
</script>
}
