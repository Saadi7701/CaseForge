@{
    ViewData["Title"] = "Generate New Case";
}

<section class="relative min-h-screen py-16 px-4 sm:px-6 lg:px-8">

    {{-- Page Heading --}}
    <div class="max-w-5xl mx-auto text-center mb-12">
        <h1 class="font-serif text-4xl md:text-5xl tracking-widest text-noir-gold text-glow-gold mb-3">
            AI CASE GENERATOR
        </h1>
        <div class="w-24 h-px bg-gradient-to-r from-transparent via-noir-gold to-transparent mx-auto mb-4"></div>
        <p class="font-sans text-noir-ivory/60 text-sm tracking-wide uppercase">
            Forge intricate mysteries from a single spark of imagination
        </p>
    </div>

    {{-- Error Message --}}
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="max-w-3xl mx-auto mb-8">
            <div class="glass-panel border border-red-500/40 rounded-lg px-6 py-4 flex items-center gap-3">
                <i class="fa-solid fa-triangle-exclamation text-red-400 text-lg"></i>
                <p class="font-sans text-red-300 text-sm">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }

    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">

        {{-- Main Form Panel --}}
        <div class="lg:col-span-2">
            <form method="post" asp-action="GenerateCase" class="glass-panel rounded-xl p-8 border border-noir-gold/20">

                {{-- Section Label --}}
                <div class="flex items-center gap-3 mb-6">
                    <i class="fa-solid fa-wand-magic-sparkles text-noir-gold text-lg"></i>
                    <h2 class="font-serif text-lg text-noir-ivory tracking-wider uppercase">Case Parameters</h2>
                </div>

                {{-- Prompt Textarea --}}
                <div class="mb-6">
                    <label for="prompt" class="block font-sans text-xs text-noir-brass uppercase tracking-widest mb-2">
                        Mystery Scenario Prompt
                    </label>
                    <textarea
                        id="prompt"
                        name="prompt"
                        rows="5"
                        minlength="3"
                        required
                        placeholder="Describe your mystery scenario... e.g. A murder at a Victorian art gallery during a midnight auction"
                        class="w-full bg-noir-obsidian/60 border border-noir-gold/20 rounded-lg px-4 py-3
                               font-sans text-noir-ivory text-sm leading-relaxed
                               placeholder:text-noir-ivory/30
                               focus:outline-none focus:border-noir-gold/60 focus:ring-1 focus:ring-noir-gold/30
                               transition-all duration-300 resize-y min-h-[6rem]"
                    ></textarea>
                </div>

                {{-- Model Selector --}}
                <div class="mb-8">
                    <label for="model" class="block font-sans text-xs text-noir-brass uppercase tracking-widest mb-2">
                        AI Model
                    </label>
                    <div class="relative">
                        <select
                            id="model"
                            name="model"
                            class="w-full appearance-none bg-noir-obsidian/60 border border-noir-gold/20 rounded-lg
                                   px-4 py-3 pr-10
                                   font-sans text-noir-ivory text-sm
                                   focus:outline-none focus:border-noir-gold/60 focus:ring-1 focus:ring-noir-gold/30
                                   transition-all duration-300 cursor-pointer">
                            <option value="google/gemma-2-9b-it:free" selected>google/gemma-2-9b-it:free</option>
                            <option value="meta-llama/llama-3-8b-instruct:free">meta-llama/llama-3-8b-instruct:free</option>
                            <option value="mistralai/mistral-7b-instruct:free">mistralai/mistral-7b-instruct:free</option>
                            <option value="deepseek/deepseek-chat:free">deepseek/deepseek-chat:free</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <i class="fa-solid fa-chevron-down text-noir-gold/50 text-xs"></i>
                        </div>
                    </div>
                </div>

                {{-- Submit Button --}}
                <button
                    type="submit"
                    class="group relative w-full font-serif text-sm uppercase tracking-[0.25em] text-noir-obsidian
                           bg-gradient-to-r from-noir-gold via-noir-brass to-noir-gold
                           rounded-lg py-4 px-8
                           transition-all duration-500 ease-out
                           hover:shadow-[0_0_25px_rgba(212,175,55,0.4),0_0_50px_rgba(212,175,55,0.15)]
                           hover:scale-[1.01]
                           active:scale-[0.99]
                           focus:outline-none focus:ring-2 focus:ring-noir-gold/50 focus:ring-offset-2 focus:ring-offset-noir-obsidian">
                    <span class="flex items-center justify-center gap-3">
                        <i class="fa-solid fa-fire text-base group-hover:animate-pulse"></i>
                        Forge Case with AI
                        <i class="fa-solid fa-arrow-right text-xs opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"></i>
                    </span>
                </button>

            </form>
        </div>

        {{-- Side Panel: Example Prompts --}}
        <div class="lg:col-span-1">
            <div class="glass-panel rounded-xl p-6 border border-noir-gold/20 sticky top-24">

                <div class="flex items-center gap-3 mb-5">
                    <i class="fa-solid fa-lightbulb text-noir-gold text-lg"></i>
                    <h2 class="font-serif text-lg text-noir-ivory tracking-wider uppercase">Inspiration</h2>
                </div>

                <p class="font-sans text-noir-ivory/40 text-xs uppercase tracking-wider mb-4">
                    Click a prompt to use it
                </p>

                <div class="space-y-3" id="example-prompts">

                    {{-- Example 1 --}}
                    <button type="button"
                            onclick="fillPrompt(this)"
                            data-prompt="A poisoning at a country estate dinner party"
                            class="w-full text-left leather-card rounded-lg p-4
                                   border border-noir-gold/10
                                   hover:border-noir-gold/40 hover:shadow-[0_0_15px_rgba(212,175,55,0.1)]
                                   transition-all duration-300 group cursor-pointer">
                        <div class="flex items-start gap-3">
                            <i class="fa-solid fa-skull-crossbones text-noir-emerald/60 group-hover:text-noir-emerald mt-0.5 transition-colors duration-300"></i>
                            <span class="font-sans text-sm text-noir-ivory/70 group-hover:text-noir-ivory transition-colors duration-300">
                                A poisoning at a country estate dinner party
                            </span>
                        </div>
                    </button>

                    {{-- Example 2 --}}
                    <button type="button"
                            onclick="fillPrompt(this)"
                            data-prompt="A museum heist during a thunderstorm"
                            class="w-full text-left leather-card rounded-lg p-4
                                   border border-noir-gold/10
                                   hover:border-noir-gold/40 hover:shadow-[0_0_15px_rgba(212,175,55,0.1)]
                                   transition-all duration-300 group cursor-pointer">
                        <div class="flex items-start gap-3">
                            <i class="fa-solid fa-mask text-noir-emerald/60 group-hover:text-noir-emerald mt-0.5 transition-colors duration-300"></i>
                            <span class="font-sans text-sm text-noir-ivory/70 group-hover:text-noir-ivory transition-colors duration-300">
                                A museum heist during a thunderstorm
                            </span>
                        </div>
                    </button>

                    {{-- Example 3 --}}
                    <button type="button"
                            onclick="fillPrompt(this)"
                            data-prompt="An assassination at an embassy ball"
                            class="w-full text-left leather-card rounded-lg p-4
                                   border border-noir-gold/10
                                   hover:border-noir-gold/40 hover:shadow-[0_0_15px_rgba(212,175,55,0.1)]
                                   transition-all duration-300 group cursor-pointer">
                        <div class="flex items-start gap-3">
                            <i class="fa-solid fa-crosshairs text-noir-emerald/60 group-hover:text-noir-emerald mt-0.5 transition-colors duration-300"></i>
                            <span class="font-sans text-sm text-noir-ivory/70 group-hover:text-noir-ivory transition-colors duration-300">
                                An assassination at an embassy ball
                            </span>
                        </div>
                    </button>

                </div>

                {{-- Decorative Divider --}}
                <div class="mt-6 pt-5 border-t border-noir-gold/10">
                    <p class="font-sans text-noir-ivory/30 text-xs leading-relaxed">
                        <i class="fa-solid fa-circle-info mr-1"></i>
                        The AI will generate suspects, clues, evidence, and a full narrative from your prompt.
                    </p>
                </div>

            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        // Fill the textarea with clicked example prompt
        function fillPrompt(el) {
            const textarea = document.getElementById('prompt');
            const prompt = el.getAttribute('data-prompt');
            textarea.value = prompt;
            textarea.focus();

            // Animate the textarea briefly
            gsap.fromTo(textarea,
                { borderColor: 'rgba(212,175,55,0.6)', boxShadow: '0 0 20px rgba(212,175,55,0.2)' },
                { borderColor: 'rgba(212,175,55,0.2)', boxShadow: '0 0 0px rgba(212,175,55,0)', duration: 1.2, ease: 'power2.out' }
            );
        }

        // GSAP entrance animations
        document.addEventListener('DOMContentLoaded', () => {
            const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

            tl.from('h1', { y: -30, opacity: 0, duration: 0.8 })
              .from('form', { y: 40, opacity: 0, duration: 0.7 }, '-=0.4')
              .from('#example-prompts button', {
                  x: 30, opacity: 0, duration: 0.5, stagger: 0.15
              }, '-=0.3');
        });
    </script>
}
