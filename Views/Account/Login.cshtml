@model CaseForgeAI.Controllers.LoginInputModel
@{
    ViewData["Title"] = "Login";
}

<div class="flex justify-center items-center py-16 px-4">
    <div class="glass-panel rounded-xl p-6 sm:p-10 w-full max-w-full sm:max-w-md border border-noir-gold/20 space-y-6 mx-2 sm:mx-0">
        <div class="text-center space-y-2">
            <i class="fa-solid fa-user-shield text-noir-gold text-4xl"></i>
            <h1 class="font-serif text-3xl tracking-widest text-noir-gold font-bold">SIGN IN</h1>
            <p class="text-xs text-noir-brass tracking-wider uppercase font-serif">Enter the Bureau</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs text-center"></div>

        <form asp-action="Login" method="post" class="space-y-5">
            <!-- Email -->
            <div class="form-field">
                <label asp-for="Email" class="text-xs uppercase tracking-widest text-noir-brass font-serif">Email Address</label>
                <div class="relative mt-1">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-noir-brass/50 text-sm"><i class="fa-solid fa-envelope"></i></span>
                    <input asp-for="Email" type="email"
                           class="w-full pl-10 pr-4 py-3 bg-noir-obsidian/80 border border-noir-gold/20 rounded text-noir-ivory placeholder:text-noir-brass/40 focus:border-noir-gold focus:outline-none focus:shadow-[0_0_10px_rgba(212,175,55,0.2)] transition text-sm"
                           placeholder="detective@caseforge.com" />
                </div>
                <span asp-validation-for="Email" class="text-red-400 text-xs"></span>
            </div>

            <!-- Password -->
            <div class="form-field">
                <label asp-for="Password" class="text-xs uppercase tracking-widest text-noir-brass font-serif">Password</label>
                <div class="relative mt-1">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-noir-brass/50 text-sm"><i class="fa-solid fa-lock"></i></span>
                    <input asp-for="Password" type="password"
                           class="w-full pl-10 pr-4 py-3 bg-noir-obsidian/80 border border-noir-gold/20 rounded text-noir-ivory placeholder:text-noir-brass/40 focus:border-noir-gold focus:outline-none focus:shadow-[0_0_10px_rgba(212,175,55,0.2)] transition text-sm"
                           placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                </div>
                <span asp-validation-for="Password" class="text-red-400 text-xs"></span>
            </div>
            <div class="flex items-center space-x-2">
                <input asp-for="RememberMe" type="checkbox" class="accent-noir-gold w-4 h-4" />
                <label class="text-xs text-noir-brass">Remember me on this device</label>
            </div>
            <button type="submit" class="w-full py-3 bg-gradient-to-r from-noir-bronze to-noir-gold text-noir-obsidian font-serif text-sm font-bold uppercase tracking-widest rounded hover:shadow-[0_0_20px_rgba(212,175,55,0.5)] hover:scale-[1.02] transition duration-300">
                Enter Bureau
            </button>
        </form>

        <div class="text-center pt-2 border-t border-white/5">
            <p class="text-xs text-noir-brass">Not yet enlisted? <a asp-action="Register" class="text-noir-gold hover:underline font-semibold">Register here</a></p>
        </div>


    </div>
</div>
