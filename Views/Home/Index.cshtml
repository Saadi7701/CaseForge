@model CaseForgeAI.Controllers.HomeViewModel
@{
    ViewData["Title"] = "Case Lobby";
}

<div class="space-y-12">
    <!-- Hero / Cinematic Greeting -->
    <div class="text-center py-10 space-y-4">
        <h1 class="font-serif text-4xl md:text-6xl font-bold tracking-widest text-noir-gold text-glow-gold">
            THE DETECTIVE LOBBY
        </h1>
        <p class="text-noir-brass text-sm md:text-base tracking-widest uppercase font-serif">
            Select a mystery case file from the archives &bull; Interrogate, decipher, accuse
        </p>
        <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-noir-gold to-transparent mx-auto"></div>
    </div>

    <!-- Active Cases Section (Slide Show / Carousel) -->
    <div class="space-y-6">
        <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
            <i class="fa-solid fa-folder-open text-noir-gold"></i>
            <span>Active Case Archives</span>
        </h2>

        @if (!Model.Stories.Any())
        {
            <div class="glass-panel rounded-lg p-10 text-center border border-noir-gold/10">
                <i class="fa-solid fa-lock text-noir-gold/30 text-5xl mb-4"></i>
                <p class="text-noir-brass text-lg">No active cases are currently published. Head to the AI Editor to draft and publish your first mystery!</p>
            </div>
        }
        else
        {
            <!-- Dynamic Slide Show Container -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 overflow-x-auto" id="caseContainer">
                @foreach (var story in Model.Stories)
                {
                    <div class="leather-card rounded-lg p-6 flex flex-col justify-between h-[380px] group border-l-4 border-l-noir-gold">
                        <div>
                            <div class="flex justify-between items-start">
                                <span class="px-2 py-0.5 bg-noir-gold/10 text-noir-gold rounded text-[10px] uppercase font-serif tracking-widest border border-noir-gold/20">
                                    @story.Difficulty
                                </span>
                                <span class="text-xs text-noir-brass"><i class="fa-solid fa-magnifying-glass mr-1"></i>Score: @(story.QualityScore * 10)</span>
                            </div>
                            <h3 class="font-serif text-xl font-bold text-white mt-4 group-hover:text-noir-gold transition">
                                @story.Title
                            </h3>
                            <p class="text-noir-brass text-xs font-serif italic mt-1">Victim: @story.VictimName</p>
                            <p class="text-noir-ivory/80 text-sm mt-4 line-clamp-4 font-sans leading-relaxed">
                                @story.Description
                            </p>
                        </div>
                        
                        <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between">
                            <div class="text-[10px] text-noir-brass">
                                <div><i class="fa-solid fa-puzzle-piece mr-1"></i>@story.Puzzles.Count Puzzles</div>
                                <div><i class="fa-solid fa-user-secret mr-1"></i>@story.Suspects.Count Suspects</div>
                            </div>
                            
                            <a asp-controller="Gameplay" asp-action="StartCase" asp-route-id="@story.Id" class="px-4 py-2 bg-noir-gold text-noir-obsidian font-serif text-xs font-bold uppercase tracking-widest rounded hover:shadow-[0_0_15px_rgba(212,175,55,0.6)] hover:scale-105 transition duration-300">
                                Investigate
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Leaderboard & Statistics Board -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- 3D Dynamic Leaderboard -->
        <div class="lg:col-span-2 space-y-6 perspective-1000">
            <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
                <i class="fa-solid fa-award text-noir-gold"></i>
                <span>Detective Leaderboard</span>
            </h2>
            
            <style>
                .perspective-1000 { perspective: 1000px; }
                .lb-card {
                    transform-style: preserve-3d;
                    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
                }
                .lb-card:hover {
                    transform: translateZ(30px) rotateX(5deg);
                    box-shadow: 0 20px 40px rgba(212,175,55,0.15);
                    border-color: rgba(212,175,55,0.5);
                }
                .podium-container {
                    display: flex;
                    align-items: flex-end;
                    justify-content: center;
                    gap: 1.5rem;
                    height: 250px;
                    margin-bottom: 2rem;
                }
                .podium-step {
                    transform-style: preserve-3d;
                    transition: transform 0.5s ease;
                    position: relative;
                }
                .podium-step:hover {
                    transform: translateY(-10px);
                }
                .podium-gold { height: 180px; background: linear-gradient(to top, rgba(212,175,55,0.1), rgba(212,175,55,0.4)); border-top: 3px solid #D4AF37; }
                .podium-silver { height: 140px; background: linear-gradient(to top, rgba(192,192,192,0.1), rgba(192,192,192,0.3)); border-top: 3px solid #C0C0C0; }
                .podium-bronze { height: 110px; background: linear-gradient(to top, rgba(205,127,50,0.1), rgba(205,127,50,0.3)); border-top: 3px solid #CD7F32; }
            </style>

            @if (Model.Leaderboard.Any())
            {
                <!-- 3D Podium for Top 3 -->
                var top3 = Model.Leaderboard.Take(3).ToList();
                <div class="podium-container flex flex-col md:flex-row items-end justify-center gap-4 md:gap-6 h-auto md:h-250px mb-6">
                    <!-- Rank 2 (Silver) -->
                    @if (top3.Count > 1) {
                        <div class="podium-step podium-silver w-24 md:w-32 h-[80px] sm:h-[140px] rounded-t-lg flex flex-col items-center justify-start pt-4 border-x border-x-white/10" id="podium2">
                            <i class="fa-solid fa-medal text-3xl text-gray-300 mb-2 drop-shadow-[0_0_10px_rgba(192,192,192,0.8)]"></i>
                            <div class="font-serif font-bold text-white text-center text-xs md:text-sm px-1 truncate w-full">@top3[1].FullName</div>
                            <div class="text-gray-300 font-mono text-xs mt-1">@top3[1].Score</div>
                        </div>
                    }

                    <!-- Rank 1 (Gold) -->
                    @if (top3.Count > 0) {
                        <div class="podium-step podium-gold w-28 md:w-40 h-[140px] sm:h-[180px] rounded-t-lg flex flex-col items-center justify-start pt-4 border-x border-x-noir-gold/30 z-10 shadow-[0_-10px_40px_rgba(212,175,55,0.2)]" id="podium1">
                            <i class="fa-solid fa-crown text-5xl text-noir-gold mb-2 drop-shadow-[0_0_15px_rgba(212,175,55,1)]"></i>
                            <div class="font-serif font-bold text-white text-center text-sm md:text-base px-1 truncate w-full">@top3[0].FullName</div>
                            <div class="text-noir-gold font-mono text-sm mt-1 font-bold">@top3[0].Score pts</div>
                        </div>
                    }

                    <!-- Rank 3 (Bronze) -->
                    @if (top3.Count > 2) {
                        <div class="podium-step podium-bronze w-24 md:w-32 h-[70px] sm:h-[110px] rounded-t-lg flex flex-col items-center justify-start pt-4 border-x border-x-orange-900/10" id="podium3">
                            <i class="fa-solid fa-award text-3xl text-orange-400 mb-2 drop-shadow-[0_0_10px_rgba(205,127,50,0.8)]"></i>
                            <div class="font-serif font-bold text-white text-center text-xs md:text-sm px-1 truncate w-full">@top3[2].FullName</div>
                            <div class="text-orange-300 font-mono text-xs mt-1">@top3[2].Score</div>
                        </div>
                    }
                </div>

                <!-- Hovering 3D Cards for Remaining Ranks -->
                <div class="space-y-3" id="lbCardsContainer">
                    @for (int i = 3; i < Model.Leaderboard.Count; i++)
                    {
                        var entry = Model.Leaderboard[i];
                        <div class="lb-card glass-panel flex items-center justify-between p-4 rounded-lg border border-white/5 bg-noir-charcoal/40">
                            <div class="flex items-center space-x-4">
                                <div class="w-8 h-8 rounded bg-noir-obsidian border border-noir-gold/20 flex items-center justify-center font-mono text-xs text-noir-gold">
                                    #@(i + 1)
                                </div>
                                <div>
                                    <h4 class="font-serif font-bold text-white text-sm">@entry.FullName</h4>
                                    <p class="text-[10px] text-noir-brass uppercase tracking-widest mt-0.5">@entry.Rank</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-mono text-sm text-noir-ivory">@entry.Score pts</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="glass-panel rounded-lg p-10 text-center border border-noir-gold/10">
                    <p class="text-noir-brass text-lg font-serif">No detectives have registered cases yet. Enlist today to start scoring!</p>
                </div>
            }
        </div>

        <!-- Bulletin Board Info / Tips -->
        <div class="space-y-6">
            <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
                <i class="fa-solid fa-scroll text-noir-gold"></i>
                <span>Bureau Directives</span>
            </h2>
            
            <div class="glass-panel rounded-lg p-6 border border-noir-gold/10 h-[380px] flex flex-col justify-between">
                <div class="space-y-4">
                    <p class="font-serif text-xs uppercase tracking-wider text-noir-gold font-bold">Investigation Procedures:</p>
                    <ul class="text-xs text-noir-brass space-y-3 list-disc pl-4 leading-relaxed font-sans">
                        <li>Hover over hotspots inside crime scenes to uncover physical clues.</li>
                        <li>Search suspect statements for logical inconsistencies.</li>
                        <li>Decrypt hidden messages using ciphers to crack locks and diaries.</li>
                        <li>Use the Evidence Board to link items. Connect dots to form connections.</li>
                        <li>Accuse the killer carefully. An incorrect accusation fails the mission.</li>
                    </ul>
                </div>
                <div class="border-t border-white/5 pt-4 text-center">
                    <span class="text-[10px] text-noir-gold font-serif tracking-widest uppercase">Bureau of Forensic Analytics &bull; 1926</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Podium animations
            gsap.from('#podium2', { y: 50, opacity: 0, duration: 0.8, ease: 'back.out(1.2)', delay: 0.2 });
            gsap.from('#podium1', { y: 80, opacity: 0, duration: 1, ease: 'back.out(1.5)', delay: 0.5 });
            gsap.from('#podium3', { y: 40, opacity: 0, duration: 0.7, ease: 'back.out(1)', delay: 0.8 });
            
            // 3D Card staggering
            gsap.from('.lb-card', {
                x: 30, opacity: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out', delay: 1
            });
        });
    </script>
}
