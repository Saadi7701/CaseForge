@model CaseForgeAI.Controllers.HomeViewModel
@{
    ViewData["Title"] = "Case Lobby";
}

<div class="space-y-12">
    <!-- Hero / Cinematic Greeting -->
    <div class="text-center py-10 space-y-4">
        <h1 class="font-serif text-4xl md:text-6xl font-bold tracking-widest text-noir-gold text-glow-gold">
            THE DETECTIVE LOBBY
        </h1>
        <p class="text-noir-brass text-sm md:text-base tracking-widest uppercase font-serif">
            Select a mystery case file from the archives &bull; Interrogate, decipher, accuse
        </p>
        <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-noir-gold to-transparent mx-auto"></div>
    </div>

    <!-- Active Cases Section (Slide Show / Carousel) -->
    <div class="space-y-6">
        <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
            <i class="fa-solid fa-folder-open text-noir-gold"></i>
            <span>Active Case Archives</span>
        </h2>

        @if (!Model.Stories.Any())
        {
            <div class="glass-panel rounded-lg p-10 text-center border border-noir-gold/10">
                <i class="fa-solid fa-lock text-noir-gold/30 text-5xl mb-4"></i>
                <p class="text-noir-brass text-lg">No active cases are currently published. Head to the AI Editor to draft and publish your first mystery!</p>
            </div>
        }
        else
        {
            <!-- Dynamic Slide Show Container -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="caseContainer">
                @foreach (var story in Model.Stories)
                {
                    <div class="leather-card rounded-lg p-6 flex flex-col justify-between h-[380px] group border-l-4 border-l-noir-gold">
                        <div>
                            <div class="flex justify-between items-start">
                                <span class="px-2 py-0.5 bg-noir-gold/10 text-noir-gold rounded text-[10px] uppercase font-serif tracking-widest border border-noir-gold/20">
                                    @story.Difficulty
                                </span>
                                <span class="text-xs text-noir-brass"><i class="fa-solid fa-magnifying-glass mr-1"></i>Score: @(story.QualityScore * 10)</span>
                            </div>
                            <h3 class="font-serif text-xl font-bold text-white mt-4 group-hover:text-noir-gold transition">
                                @story.Title
                            </h3>
                            <p class="text-noir-brass text-xs font-serif italic mt-1">Victim: @story.VictimName</p>
                            <p class="text-noir-ivory/80 text-sm mt-4 line-clamp-4 font-sans leading-relaxed">
                                @story.Description
                            </p>
                        </div>
                        
                        <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between">
                            <div class="text-[10px] text-noir-brass">
                                <div><i class="fa-solid fa-puzzle-piece mr-1"></i>@story.Puzzles.Count Puzzles</div>
                                <div><i class="fa-solid fa-user-secret mr-1"></i>@story.Suspects.Count Suspects</div>
                            </div>
                            
                            <a asp-controller="Gameplay" asp-action="StartCase" asp-route-id="@story.Id" class="px-4 py-2 bg-noir-gold text-noir-obsidian font-serif text-xs font-bold uppercase tracking-widest rounded hover:shadow-[0_0_15px_rgba(212,175,55,0.6)] hover:scale-105 transition duration-300">
                                Investigate
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Leaderboard & Statistics Board -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Leaderboard -->
        <div class="lg:col-span-2 space-y-6">
            <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
                <i class="fa-solid fa-award text-noir-gold"></i>
                <span>Detective Leaderboard</span>
            </h2>
            
            <div class="glass-panel rounded-lg p-6 border border-noir-gold/10 overflow-hidden relative">
                <div class="document-frame">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm">
                            <thead class="font-serif uppercase tracking-widest text-noir-gold text-xs border-b border-noir-gold/20">
                                <tr>
                                    <th class="pb-3">Rank</th>
                                    <th class="pb-3">Detective</th>
                                    <th class="pb-3">Clearance Rating</th>
                                    <th class="pb-3 text-right">Points</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5 text-noir-ivory/80">
                                @for (int i = 0; i < Model.Leaderboard.Count; i++)
                                {
                                    var entry = Model.Leaderboard[i];
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="py-3 font-serif font-bold text-noir-gold">
                                            #@(i + 1)
                                        </td>
                                        <td class="py-3 font-semibold text-white">
                                            @entry.FullName
                                        </td>
                                        <td class="py-3 text-xs">
                                            @entry.Rank
                                        </td>
                                        <td class="py-3 text-right font-mono text-noir-gold">
                                            @entry.Score
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Leaderboard.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="py-6 text-center text-noir-brass">
                                            No detectives have registered cases yet. Enlist today to start scoring!
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulletin Board Info / Tips -->
        <div class="space-y-6">
            <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
                <i class="fa-solid fa-scroll text-noir-gold"></i>
                <span>Bureau Directives</span>
            </h2>
            
            <div class="glass-panel rounded-lg p-6 border border-noir-gold/10 h-[380px] flex flex-col justify-between">
                <div class="space-y-4">
                    <p class="font-serif text-xs uppercase tracking-wider text-noir-gold font-bold">Investigation Procedures:</p>
                    <ul class="text-xs text-noir-brass space-y-3 list-disc pl-4 leading-relaxed font-sans">
                        <li>Hover over hotspots inside crime scenes to uncover physical clues.</li>
                        <li>Search suspect statements for logical inconsistencies.</li>
                        <li>Decrypt hidden messages using ciphers to crack locks and diaries.</li>
                        <li>Use the Evidence Board to link items. Connect dots to form connections.</li>
                        <li>Accuse the killer carefully. An incorrect accusation fails the mission.</li>
                    </ul>
                </div>
                <div class="border-t border-white/5 pt-4 text-center">
                    <span class="text-[10px] text-noir-gold font-serif tracking-widest uppercase">Bureau of Forensic Analytics &bull; 1926</span>
                </div>
            </div>
        </div>
    </div>
</div>
