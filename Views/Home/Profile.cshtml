@model CaseForgeAI.Controllers.UserProfileViewModel
@{
    ViewData["Title"] = "Detective Profile";
}

<style>
    /* 3D Card Hover Styles */
    .stat-card-3d {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        transform-style: preserve-3d;
        perspective: 1000px;
    }
    .stat-card-3d:hover {
        transform: translateY(-5px) scale(1.02);
    }
    .stat-card-3d::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        box-shadow: 0 15px 35px rgba(212, 175, 55, 0.1);
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: -1;
    }
    .stat-card-3d:hover::after {
        opacity: 1;
    }

    /* Rank Badge Glow */
    .rank-badge {
        position: relative;
        background: radial-gradient(circle at center, rgba(212, 175, 55, 0.2) 0%, transparent 70%);
        animation: pulseGlow 3s infinite alternate;
    }
    
    @@keyframes pulseGlow {
        0% { filter: drop-shadow(0 0 10px rgba(212,175,55,0.2)); }
        100% { filter: drop-shadow(0 0 25px rgba(212,175,55,0.6)); }
    }
    
    /* Radial Progress Bar */
    .circular-chart {
        display: block;
        margin: 0 auto;
        max-width: 80%;
        max-height: 250px;
    }
    .circle-bg {
        fill: none;
        stroke: rgba(255,255,255,0.05);
        stroke-width: 3.8;
    }
    .circle {
        fill: none;
        stroke-width: 2.8;
        stroke-linecap: round;
        animation: progress 1s ease-out forwards;
    }
    @@keyframes progress {
        0% { stroke-dasharray: 0 100; }
    }
    .percentage {
        fill: #D4AF37;
        font-family: serif;
        font-size: 0.5em;
        text-anchor: middle;
        font-weight: bold;
    }
</style>

<div class="space-y-12">
    <!-- Header -->
    <div class="text-center py-8 space-y-4">
        <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-widest text-noir-gold text-glow-gold" id="profileTitle">
            DETECTIVE PROFILE
        </h1>
        <p class="text-noir-brass text-sm md:text-base tracking-widest uppercase font-serif" id="profileSubtitle">
            Identity Confirmed: @Model.FullName
        </p>
        <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-noir-gold to-transparent mx-auto"></div>
    </div>

    <!-- Main Analytics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Left: Rank & Overall Points -->
        <div class="stat-card-3d glass-panel rounded-xl p-8 border border-noir-gold/20 flex flex-col items-center justify-center text-center space-y-6">
            <div class="rank-badge w-32 h-32 rounded-full border border-noir-gold/30 flex items-center justify-center">
                <i class="fa-solid fa-user-secret text-6xl text-noir-gold"></i>
            </div>
            <div>
                <h3 class="font-serif text-2xl text-white tracking-widest uppercase">@Model.DetectiveRank</h3>
                <p class="text-noir-brass/60 text-xs font-sans tracking-widest uppercase mt-2">Current Rank</p>
            </div>
            
            <div class="w-full h-px bg-gradient-to-r from-transparent via-noir-gold/20 to-transparent"></div>
            
            <div>
                <h2 class="font-serif text-5xl font-bold text-noir-gold">@Model.TotalScore</h2>
                <p class="text-noir-brass/60 text-xs font-sans tracking-widest uppercase mt-2">Total Reputation Points</p>
            </div>
        </div>

        <!-- Middle: Accuracy Ring -->
        <div class="stat-card-3d glass-panel rounded-xl p-8 border border-white/5 flex flex-col items-center justify-center text-center">
            <h3 class="font-serif text-lg text-white tracking-widest uppercase mb-6">Investigative Accuracy</h3>
            
            <svg viewBox="0 0 36 36" class="circular-chart text-noir-gold">
                <path class="circle-bg"
                    d="M18 2.0845
                    a 15.9155 15.9155 0 0 1 0 31.831
                    a 15.9155 15.9155 0 0 1 0 -31.831"
                />
                <path class="circle"
                    stroke="currentColor"
                    stroke-dasharray="@Model.AccuracyPercentage, 100"
                    d="M18 2.0845
                    a 15.9155 15.9155 0 0 1 0 31.831
                    a 15.9155 15.9155 0 0 1 0 -31.831"
                />
                <text x="18" y="20.35" class="percentage">@Model.AccuracyPercentage%</text>
            </svg>
            
            <p class="text-noir-ivory/60 text-sm font-sans mt-6">Based on cases solved vs attempted.</p>
        </div>

        <!-- Right: Case Stats -->
        <div class="stat-card-3d glass-panel rounded-xl p-8 border border-white/5 flex flex-col justify-center space-y-8">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-noir-brass/60 text-xs font-sans tracking-widest uppercase">Cases Attempted</p>
                    <h3 class="font-serif text-3xl font-bold text-white mt-1">@Model.TotalCasesAttempted</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                    <i class="fa-solid fa-magnifying-glass text-xl text-white/50"></i>
                </div>
            </div>
            
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-green-400/60 text-xs font-sans tracking-widest uppercase">Cases Solved</p>
                    <h3 class="font-serif text-3xl font-bold text-green-400 mt-1">@Model.TotalCasesSolved</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-green-500/10 border border-green-500/20 flex items-center justify-center">
                    <i class="fa-solid fa-check-double text-xl text-green-400"></i>
                </div>
            </div>
            
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-red-400/60 text-xs font-sans tracking-widest uppercase">Cold Cases (Failed)</p>
                    <h3 class="font-serif text-3xl font-bold text-red-400 mt-1">@(Model.TotalCasesAttempted - Model.TotalCasesSolved)</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center">
                    <i class="fa-solid fa-xmark text-xl text-red-400"></i>
                </div>
            </div>
        </div>
        
    </div>

    <!-- Recent Activity Board -->
    <div class="space-y-6 pt-6">
        <h2 class="font-serif text-2xl tracking-wider text-white border-b border-noir-gold/10 pb-2 flex items-center space-x-2">
            <i class="fa-solid fa-timeline text-noir-gold"></i>
            <span>Recent Case History</span>
        </h2>
        
        <div class="glass-panel rounded-xl border border-noir-gold/10 overflow-hidden overflow-x-auto">
            @if (!Model.RecentActivity.Any())
            {
                <div class="p-10 text-center text-noir-brass">
                    <i class="fa-solid fa-ghost text-4xl mb-3 opacity-50"></i>
                    <p>No recent activity on file. Begin an investigation from the Lobby.</p>
                </div>
            }
            else
            {
                <div class="divide-y divide-white/5">
                    @foreach (var activity in Model.RecentActivity)
                    {
                        <div class="p-6 flex flex-col md:flex-row md:items-center justify-between hover:bg-white/5 transition-colors group">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 rounded-full border flex items-center justify-center @(activity.CaseSolved ? "border-green-500/30 bg-green-500/10 text-green-400" : "border-red-500/30 bg-red-500/10 text-red-400")">
                                    <i class="fa-solid @(activity.CaseSolved ? "fa-gavel" : "fa-skull")"></i>
                                </div>
                                <div>
                                    <h4 class="font-serif text-lg text-white group-hover:text-noir-gold transition-colors">@(activity.Story?.Title ?? "Unknown Case")</h4>
                                    <p class="text-xs text-noir-ivory/50 font-sans mt-1">Date: @activity.LastSavedAt.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                            <div class="mt-4 md:mt-0 text-right">
                                <span class="px-3 py-1 text-[10px] uppercase font-bold tracking-widest rounded-full border @(activity.CaseSolved ? "bg-green-500/10 text-green-400 border-green-500/20" : "bg-red-500/10 text-red-400 border-red-500/20")">
                                    @(activity.CaseSolved ? "SOLVED" : "FAILED")
                                </span>
                                @if(activity.CaseSolved)
                                {
                                    <p class="text-sm font-serif font-bold text-noir-gold mt-2">
                                        +@activity.Score pts
                                    </p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            gsap.from('#profileTitle, #profileSubtitle', {
                y: -30, opacity: 0, duration: 0.8, stagger: 0.1, ease: 'power3.out'
            });
            
            gsap.from('.stat-card-3d', {
                y: 50, opacity: 0, duration: 0.8, stagger: 0.15, ease: 'back.out(1.2)', delay: 0.3
            });
            
            gsap.from('.glass-panel .flex', {
                x: -20, opacity: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out', delay: 0.8
            });
        });
    </script>
}
